{
  "name": "emery-design-studio",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@repo/eslint-config": "workspace:*",
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "syncpack": "^14.3.0",
    "tsc-files": "^1.1.4",
    "turbo": "^2.9.6",
    "typescript": "5"
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "prepare": "husky",
    "s:lint": "syncpack lint --dependency-types prod,dev,peer",
    "s:fix": "syncpack fix --dependency-types prod,dev,peer"
  },
  "syncpack": {
    "semverGroups": [
      {
        "label": "Exact versions for core framework packages",
        "packages": [
          "**"
        ],
        "dependencies": [
          "typescript",
          "react",
          "react-dom",
          "@types/react",
          "@types/react-dom",
          "next",
          "sanity"
        ],
        "range": ""
      },
      {
        "label": "Caret range for everything else",
        "packages": [
          "**"
        ],
        "dependencies": [
          "**"
        ],
        "range": "^"
      }
    ],
    "versionGroups": [
      {
        "label": "Use workspace protocol for internal packages",
        "packages": [
          "**"
        ],
        "dependencies": [
          "@repo/*"
        ],
        "dependencyTypes": [
          "dev",
          "prod",
          "peer"
        ],
        "pinVersion": "workspace:*"
      }
    ]
  }
}
